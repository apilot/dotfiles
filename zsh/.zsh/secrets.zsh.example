# =====================================================
# API Keys and Secrets Template
# Copy this file to secrets.zsh and fill in your keys
# File permissions: chmod 600
# =====================================================

# Anthropic API
export ANTHROPIC_BASE_URL="https://api.anthropic.com"
export ANTHROPIC_AUTH_TOKEN="your_anthropic_token_here"

# Context7 API
export CONTEXT7_API_KEY="your_context7_key_here"

# Z AI API
export Z_AI_API_KEY="your_zai_key_here"

# OpenAI API
export OPENAI_API_KEY="your_openai_key_here"
export OPENAI_BASE_URL="https://api.openai.com/v1/"
export OPENAI_MODEL="gpt-4"
