// Project tasks configuration - ported from Neovim FzfLua
[
  // ============================================
  // GIT OPERATIONS (leader+g)
  // ============================================
  {
    "label": "lazygit",
    "command": "kitty --class 'dotfiles.floating' -e lazygit",
    "args": [],
    "env": {},
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "working_directory": "${ZED_WORKTREE_ROOT}",
    "hide": "on_success",
    "reveal": "always"
  },

  // ============================================
  // FILE SEARCH (FzfLua files equivalent)
  // ============================================
  {
    "label": "Files",
    "command": "kitty --class 'dotfiles.floating' -e sh -c \"FILE=\\$(rg --files --hidden -g '!.git' -g '!node_modules' -g '!.bundle' | fzf --preview 'bat -n --color=always {}' --preview-window 'right:50%' --style full --layout reverse --border --height 90% --prompt 'Files> '); [ -n \\\"\\$FILE\\\" ] && zed \\\"\\$FILE\\\"\"",
    "hide": "always",
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "reveal_target": "center"
  },

  // ============================================
  // LIVE GREP (FzfLua live_grep equivalent)
  // ============================================
  {
    "label": "Rg",
    "command": "kitty --class 'dotfiles.floating' -e sh -c \"QUERY=\\$(echo '' | fzf --print-query --no-sort --reverse --height 90% --prompt 'Search> ' --preview 'rg --column --line-number --no-heading --color=always --smart-case {q} | head -100' --preview-window 'down:70%' --bind 'change:reload:rg --column --line-number --no-heading --color=always --smart-case {q} || true' | head -1); [ -n \\\"\\$QUERY\\\" ] && FILE=\\$(rg --column --line-number --no-heading --color=always --smart-case \\\"\\$QUERY\\\" | fzf --bind 'enter:become(echo {1}:{2})' --ansi --delimiter : --nth {4..} --preview 'bat -n --color=always --highlight-line {2} {1}' --preview-window '+{2}-/2' --style full --layout reverse --border --height 90% --prompt 'Results> '); [ -n \\\"\\$FILE\\\" ] && zed \\\"\\$FILE\\\"\"",
    "hide": "always",
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "reveal_target": "center"
  },

  // ============================================
  // BUFFER LIST (FzfLua buffers equivalent)
  // ============================================
  {
    "label": "Buffers",
    "command": "kitty --class 'dotfiles.floating' -e sh -c \"FILE=\\$(ls -t | head -20 | fzf --preview 'bat -n --color=always {}' --preview-window 'right:50%' --style full --layout reverse --border --height 90% --prompt 'Buffers> '); [ -n \\\"\\$FILE\\\" ] && zed \\\"\\$FILE\\\"\"",
    "hide": "always",
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "reveal_target": "center"
  },

  // ============================================
  // GIT FILES (FzfLua git_files equivalent)
  // ============================================
  {
    "label": "GitFiles",
    "command": "kitty --class 'dotfiles.floating' -e sh -c \"FILE=\\$(git -C ${ZED_WORKTREE_ROOT} ls-files | fzf --preview 'bat -n --color=always {}' --preview-window 'right:50%' --style full --layout reverse --border --height 90% --prompt 'Git Files> '); [ -n \\\"\\$FILE\\\" ] && zed \\\"\\$FILE\\\"\"",
    "hide": "always",
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "reveal_target": "center"
  },

  // ============================================
  // RECENT FILES (FzfLua oldfiles equivalent)
  // ============================================
  {
    "label": "Recent",
    "command": "kitty --class 'dotfiles.floating' -e sh -c \"FILE=\\$(find ${ZED_WORKTREE_ROOT} -type f -mtime -7 -not -path '*/.git/*' -not -path '*/node_modules/*' -not -path '*/.bundle/*' | fzf --preview 'bat -n --color=always {}' --preview-window 'right:50%' --style full --layout reverse --border --height 90% --prompt 'Recent> '); [ -n \\\"\\$FILE\\\" ] && zed \\\"\\$FILE\\\"\"",
    "hide": "always",
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "reveal_target": "center"
  },

  // ============================================
  // COMMANDS (FzfLua commands equivalent)
  // ============================================
  {
    "label": "Commands",
    "command": "zed --open-help",
    "hide": "always",
    "allow_concurrent_runs": false,
    "use_new_terminal": false,
    "reveal": "always"
  },

  // ============================================
  // HELP TAGS (FzfLua help_tags equivalent)
  // ============================================
  {
    "label": "Help",
    "command": "zed --open-help",
    "hide": "always",
    "allow_concurrent_runs": false,
    "use_new_terminal": false,
    "reveal": "always"
  },

  // ============================================
  // LSP REFERENCES (FzfLua lsp_references equivalent)
  // ============================================
  {
    "label": "LspReferences",
    "command": "zed --show-references",
    "hide": "always",
    "allow_concurrent_runs": false,
    "use_new_terminal": false,
    "reveal": "always"
  },

  // ============================================
  // LSP DEFINITIONS (FzfLua lsp_definitions equivalent)
  // ============================================
  {
    "label": "LspDefinitions",
    "command": "zed --go-to-definition",
    "hide": "always",
    "allow_concurrent_runs": false,
    "use_new_terminal": false,
    "reveal": "always"
  },

  // ============================================
  // LSP IMPLEMENTATIONS (FzfLua lsp_implementations equivalent)
  // ============================================
  {
    "label": "LspImplementations",
    "command": "zed --go-to-implementation",
    "hide": "always",
    "allow_concurrent_runs": false,
    "use_new_terminal": false,
    "reveal": "always"
  },

  // ============================================
  // WHICH KEY REFERENCE (nvim which-key equivalent)
  // ============================================
  {
    "label": "WhichKey",
    "command": "kitty --class 'dotfiles.floating' -e ~/.config/zed/which-key-fzf.sh",
    "hide": "on_success",
    "allow_concurrent_runs": false,
    "use_new_terminal": true,
    "reveal_target": "center"
  }
]
